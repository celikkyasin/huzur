<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_ayah_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <ImageView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:contentDescription="@null"
    android:scaleType="centerCrop"
    android:src="@drawable/widget_prayer_hero_bg" />

  <View
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_image_scrim" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="15dp">

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:letterSpacing="0.08"
      android:text="SAATLİK AYET"
      android:textColor="#EBD8A1"
      android:textSize="11sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_ayah_arabic"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="9dp"
      android:fontFamily="serif"
      android:gravity="center"
      android:maxLines="2"
      android:text="اِنَّ مَعَ الْعُسْرِ يُسْرًا"
      android:textColor="#FFFFFF"
      android:textSize="25sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_ayah_translation"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="9dp"
      android:ellipsize="end"
      android:fontFamily="serif"
      android:gravity="center"
      android:maxLines="3"
      android:text="Şüphesiz her zorlukla beraber bir kolaylık vardır."
      android:textColor="#FFF7E5"
      android:textSize="17sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_ayah_source"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_marginTop="12dp"
      android:background="@drawable/widget_primary_pill"
      android:gravity="center"
      android:maxLines="1"
      android:paddingLeft="14dp"
      android:paddingTop="5dp"
      android:paddingRight="14dp"
      android:paddingBottom="5dp"
      android:text="İnşirah Suresi, 6"
      android:textColor="#073D33"
      android:textSize="12sp"
      android:textStyle="bold" />
  </LinearLayout>
</FrameLayout>
