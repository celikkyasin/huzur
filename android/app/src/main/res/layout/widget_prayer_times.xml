<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_prayer_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_premium_background"
  android:padding="14dp">

  <ImageView
    android:layout_width="158dp"
    android:layout_height="118dp"
    android:layout_gravity="right|bottom"
    android:alpha="0.75"
    android:contentDescription="@null"
    android:src="@drawable/widget_mosque_watermark" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/widget_prayer_location"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="sans"
        android:maxLines="1"
        android:text="Kütahya, Türkiye"
        android:textColor="#F9F2DE"
        android:textSize="13sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_prayer_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_primary_pill"
        android:fontFamily="sans"
        android:paddingLeft="9dp"
        android:paddingTop="4dp"
        android:paddingRight="9dp"
        android:paddingBottom="4dp"
        android:text="Bugün"
        android:textColor="#073D33"
        android:textSize="10sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:fontFamily="sans"
      android:gravity="center"
      android:letterSpacing="0.08"
      android:text="SIRADAKİ VAKİT"
      android:textColor="#D9C28A"
      android:textSize="10sp"
      android:textStyle="bold" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/widget_next_prayer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:gravity="center"
        android:text="İmsak"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_next_prayer_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:background="@drawable/widget_soft_panel"
        android:fontFamily="sans"
        android:gravity="center"
        android:paddingLeft="10dp"
        android:paddingTop="4dp"
        android:paddingRight="10dp"
        android:paddingBottom="4dp"
        android:text="03:51"
        android:textColor="#F3DFA5"
        android:textSize="13sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/widget_next_prayer_countdown"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:fontFamily="sans"
      android:gravity="center"
      android:text="5 sa 46 dk kaldı"
      android:textColor="#F3DFA5"
      android:textSize="17sp"
      android:textStyle="bold" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_marginTop="11dp"
      android:layout_weight="1"
      android:gravity="bottom"
      android:orientation="horizontal">

      <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginRight="5dp" android:layout_weight="1" android:background="@drawable/widget_soft_panel" android:gravity="center" android:orientation="vertical" android:padding="5dp">
        <TextView android:id="@+id/widget_time_name_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:maxLines="1" android:text="İmsak" android:textColor="#EBD8A1" android:textSize="10sp" android:textStyle="bold" />
        <TextView android:id="@+id/widget_time_value_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:maxLines="1" android:text="03:51" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
      </LinearLayout>

      <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginRight="5dp" android:layout_weight="1" android:background="@drawable/widget_soft_panel" android:gravity="center" android:orientation="vertical" android:padding="5dp">
        <TextView android:id="@+id/widget_time_name_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:maxLines="1" android:text="Güneş" android:textColor="#EBD8A1" android:textSize="10sp" android:textStyle="bold" />
        <TextView android:id="@+id/widget_time_value_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:maxLines="1" android:text="05:26" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
      </LinearLayout>

      <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginRight="5dp" android:layout_weight="1" android:background="@drawable/widget_soft_panel" android:gravity="center" android:orientation="vertical" android:padding="5dp">
        <TextView android:id="@+id/widget_time_name_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:maxLines="1" android:text="Öğle" android:textColor="#EBD8A1" android:textSize="10sp" android:textStyle="bold" />
        <TextView android:id="@+id/widget_time_value_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:maxLines="1" android:text="12:40" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
      </LinearLayout>

      <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/widget_soft_panel" android:gravity="center" android:orientation="vertical" android:padding="5dp">
        <TextView android:id="@+id/widget_time_name_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:maxLines="1" android:text="İkindi" android:textColor="#EBD8A1" android:textSize="10sp" android:textStyle="bold" />
        <TextView android:id="@+id/widget_time_value_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:maxLines="1" android:text="16:58" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
      </LinearLayout>
    </LinearLayout>

    <TextView
      android:id="@+id/widget_prayer_source"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="7dp"
      android:fontFamily="sans"
      android:gravity="end"
      android:text="Diyanet vakitleri"
      android:textColor="#D9C28A"
      android:textSize="10sp" />
  </LinearLayout>
</FrameLayout>
